<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Popover
        id="myPopover"
        title="Rejection Date: {excelModel>RejectDate}"
        class="sapUiContentPadding"
        placement="Right"
        initialFocus="idClose">
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button
                    id="idClose"
                    text="Close"
                    press=".onClosePopover" />
            </OverflowToolbar>
        </footer>
        <VBox>
            <Label text="Reason : {excelModel>RejectReason} " design="Bold" wrapping="true" />
            <!-- <Text text="{excelModel>RejectReason}" /> -->
        </VBox>
    </Popover>
</core:FragmentDefinition>