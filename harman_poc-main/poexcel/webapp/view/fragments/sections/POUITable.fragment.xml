<core:FragmentDefinition
    xmlns="sap.ui.table"
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
>
    <Table
        id="idFlatPOGridTable"
        class="sapUiSizeCompact"
        rows="{excelModel>/data}"
        selectionMode="None"
        visibleRowCountMode="Interactive"
        visibleRowCount="5"
        enableGrouping="true"
    >
        <extension>
            <m:OverflowToolbar style="Clear">
                <m:Title text="Purchase Orders, Items &amp; Confirmations Grid" level="H5"/>
                <m:ToolbarSpacer/>
            </m:OverflowToolbar>
        </extension>

        <columns>
            <Column width="5rem" hAlign="Center">
                <m:Label text="Action" tooltip="Action"/>
                <template>
                    <m:Button
                        icon="sap-icon://action"
                        press=".onActionButtonPress"
                        ariaHasPopup="Menu" 
                        class="poActionBtn">
                        <m:dependents>
                            <core:Fragment
                                fragmentName="com.sap.poexcel.view.fragments.ActionSheet"
                                type="XML" />
                        </m:dependents>
                    </m:Button>
                </template>
            </Column>
            

            <Column width="6rem" hAlign="Center" sortProperty="StatusFlag" filterProperty="StatusFlag">
                <m:Label text="Conf. Status" tooltip="Conf. Status"/>
                <template>
                    <m:ObjectStatus inverted="true" visible="{= ${excelModel>StatusFlag} !== undefined &amp;&amp; ${excelModel>StatusFlag} !== '' }"
                        text="{= ${excelModel>StatusFlag} === 'R' ? 'Rejected' : (${excelModel>StatusFlag} === 'A' ? 'Approved' : 'NA')}"
                        state="{= ${excelModel>StatusFlag} === 'R' ? 'Error' : (${excelModel>StatusFlag} === 'A' ? 'Success' : 'Information')}"/>
                </template>
            </Column>

            <Column width="5rem" hAlign="Center" sortProperty="EDIFlag" filterProperty="EDIFlag">
                <m:Label text="EDI" tooltip="EDI"/>
                <template>
                    <m:ObjectStatus inverted="true"
                        visible="{= ${excelModel>EDIFlag} === 'E' ? true : false}"
                        text="{= ${excelModel>EDIFlag} === 'E' ? 'EDI' : 'SAP'}"
                        state="{= ${excelModel>EDIFlag} === 'E' ? 'Warning' : 'Information'}"/>
                </template>
            </Column>

             <Column width="4rem" hAlign="Center" sortProperty="ConfirmationCategory" filterProperty="ConfirmationCategory">
                <m:Label text="CC" tooltip="Confirmation Category"/>
                <template>
                    <m:Text  text="{excelModel>ConfirmationCategory}" wrapping="false"/>
                </template>
            </Column>

            <Column width="7rem" sortProperty="Quantity" filterProperty="Quantity">
                <m:Label text="Quantity" tooltip="Quantity"/>
                <template>
                    <m:Input value="{path: 'excelModel>Quantity', type: 'sap.ui.model.type.String', constraints: { search: '^[0-9]+$' }}"
                        visible="{= ${excelModel>ConfirmationCategory} !== undefined &amp;&amp; ${excelModel>ConfirmationCategory} !== '' }"
                        editable="{= ${excelModel>ConfirmationCategory} === 'LA' || ${excelModel>StatusFlag} === 'R' ? false : true }"
                        liveChange=".onQuantityLiveChange"/>
                </template>
            </Column>

            <Column width="9rem" hAlign="Center" sortProperty="CreationDate" filterProperty="CreationDate">
                <m:Label text="Conf. Delivery Date" tooltip="Conf. Delivery Date"/>
                <template>
                    <m:DatePicker valueState="{excelModel>DateState}" valueStateText="{excelModel>DateMsg}" value="{excelModel>CreationDate}"
                        visible="{= ${excelModel>ConfirmationCategory} !== undefined &amp;&amp; ${excelModel>ConfirmationCategory} !== '' }"
                        enabled="{= ${excelModel>ConfirmationCategory} === 'LA' || ${excelModel>StatusFlag} === 'R' ? false : true }"
                        valueFormat="MM/dd/yyyy" displayFormat="MM/dd/yyyy" placeholder="MM/DD/YYYY" change="onDateLiveChange"/>
                </template>
            </Column>

            <Column width="9rem" sortProperty="PONumber" filterProperty="PONumber">
                <m:Label text="PO Number" tooltip="PO Number"/>
                <template>
                    <m:ObjectIdentifier title="{excelModel>PONumber}"/>
                </template>
            </Column>

            <Column width="7rem" sortProperty="VendorCode" filterProperty="VendorCode">
                <m:Label text="Vendor Code" tooltip="Vendor Code"/>
                <template>
                    <m:Text text="{excelModel>VendorCode}" wrapping="false"/>
                </template>
            </Column>

            <Column width="4rem" hAlign="Center" sortProperty="Item" filterProperty="Item">
                <m:Label text="Conf. Item" tooltip="Confirmation Item"/>
                <template>
                    <m:Text text="{excelModel>Item}" wrapping="false"/>
                </template>
            </Column>
            <Column width="4rem" hAlign="Center" sortProperty="SequenceNumber" filterProperty="SequenceNumber">
                <m:Label text="SN" tooltip="Sequence Number"/>
                <template>
                    <m:Text text="{excelModel>SequenceNumber}" wrapping="false"/>
                </template>
            </Column>

            <Column width="6rem" hAlign="End" sortProperty="POQuantity" filterProperty="POQuantity">
                <m:Label text="PO Qty" tooltip="Purchase Order Quantity"/>
                <template>
                    <m:Text text="{excelModel>POQuantity}" wrapping="false"/>
                </template>
            </Column>

            <Column width="12rem" hAlign="Center" sortProperty="HarmanReqDate" filterProperty="HarmanReqDate">
                <m:Label text="Harman request Jun 7th" tooltip="Harman request Jun 7th"/>
                <template>
                    <m:Text text="{excelModel>HarmanReqDate}" wrapping="false"/>
                </template>
            </Column>

            <Column width="8rem" hAlign="Center" sortProperty="PODate" filterProperty="PODate">
                <m:Label text="PO Date" tooltip="PO Date"/>
                <template>
                    <m:Text text="{path: 'excelModel>PODate', formatter: '.formatter.formatDate'}" wrapping="false"/>
                </template>
            </Column>

            <Column width="8rem" hAlign="Begin" sortProperty="ODM" filterProperty="ODM">
                <m:Label text="ODM" tooltip="ODM"/>
                <template>
                    <m:Text text="{excelModel>ODM}" wrapping="false"/>
                </template>
            </Column>

            <Column width="10rem" hAlign="Begin" sortProperty="FactorySite" filterProperty="FactorySite">
                <m:Label text="Factory site" tooltip="Factory site"/>
                <template>
                    <m:Text text="{excelModel>FactorySite}" wrapping="false"/>
                </template>
            </Column>

            <Column width="6rem" hAlign="Center" sortProperty="Region" filterProperty="Region">
                <m:Label text="Region" tooltip="Region"/>
                <template>
                    <m:Text text="{excelModel>Region}" wrapping="false"/>
                </template>
            </Column>

            <Column width="10rem" hAlign="Begin" sortProperty="Project" filterProperty="Project">
                <m:Label text="Project" tooltip="Project"/>
                <template>
                    <m:Text text="{excelModel>Project}" wrapping="false"/>
                </template>
            </Column>

            <Column width="12rem" hAlign="Center" sortProperty="StatDelDate" filterProperty="StatDelDate">
                <m:Label text="Statistical delivery date" tooltip="Statistical delivery date"/>
                <template>
                    <m:Text text="{excelModel>StatDelDate}" wrapping="false"/>
                </template>
            </Column>

            <Column width="10rem" hAlign="Center" sortProperty="InitialDates" filterProperty="InitialDates">
                <m:Label text="Initial dates:" tooltip="Initial dates"/>
                <template>
                    <m:Text text="{excelModel>InitialDates}" wrapping="false"/>
                </template>
            </Column>

            <Column width="10rem" hAlign="Center" sortProperty="ODMCRDMar19" filterProperty="ODMCRDMar19">
                <m:Label text="ODM CRD Mar 19" tooltip="ODM CRD Mar 19"/>
                <template>
                    <m:Text text="{excelModel>ODMCRDMar19}" wrapping="false"/>
                </template>
            </Column>

            <Column width="12rem" hAlign="Begin" sortProperty="ODMRemark" filterProperty="ODMRemark">
                <m:Label text="ODM Remark" tooltip="ODM Remark"/>
                <template>
                    <m:Text text="{excelModel>ODMRemark}" wrapping="false"/>
                </template>
            </Column>

            <Column width="12rem" hAlign="Begin" sortProperty="HarmanRemark" filterProperty="HarmanRemark">
                <m:Label text="Harman Remark" tooltip="Harman Remark"/>
                <template>
                    <m:Text text="{excelModel>HarmanRemark}" wrapping="false"/>
                </template>
            </Column>

            <Column width="8rem" hAlign="Center" sortProperty="Booking" filterProperty="Booking">
                <m:Label text="Booking#" tooltip="Booking Number"/>
                <template>
                    <m:Text text="{excelModel>Booking}" wrapping="false"/>
                </template>
            </Column>

            <Column width="10rem" hAlign="Center" sortProperty="ExFtCRD" filterProperty="ExFtCRD">
                <m:Label text="Ex-factory/CRD" tooltip="Ex-factory/CRD"/>
                <template>
                    <m:Text text="{excelModel>ExFtCRD}" wrapping="false"/>
                </template>
            </Column>

            <Column width="14rem" hAlign="Begin" sortProperty="RemarkCustomerAPAC" filterProperty="RemarkCustomerAPAC">
                <m:Label text="Remark/Customer APAC" tooltip="Remark/Customer APAC"/>
                <template>
                    <m:Text text="{excelModel>RemarkCustomerAPAC}" wrapping="false"/>
                </template>
            </Column>

            

            <Column width="12rem" hAlign="Center" sortProperty="ODMFeedback" filterProperty="ODMFeedback">
                <m:Label text="ODM feedback Jun 10th" tooltip="ODM feedback Jun 10th"/>
                <template>
                    <m:Text text="{excelModel>ODMFeedback}" wrapping="false"/>
                </template>
            </Column>

            <Column width="10rem" hAlign="Center" sortProperty="ShippingMode" filterProperty="ShippingMode">
                <m:Label text="Shipping mode" tooltip="Shipping mode"/>
                <template>
                    <m:Text text="{excelModel>ShippingMode}" wrapping="false"/>
                </template>
            </Column>

            <Column width="8rem" hAlign="End" sortProperty="Balance" filterProperty="Balance">
                <m:Label text="Balance" tooltip="Balance"/>
                <template>
                    <m:Text text="{excelModel>Balance}" wrapping="false"/>
                </template>
            </Column>


            <Column width="8rem" sortProperty="Material" filterProperty="Material">
                <m:Label text="Material" tooltip="Material"/>
                <template>
                    <m:Text text="{excelModel>Material}" wrapping="false"/>
                </template>
            </Column>

            <Column width="6rem" hAlign="End" sortProperty="NetPrice" filterProperty="NetPrice">
                <m:Label text="Net Price" tooltip="Net Price"/>
                <template>
                    <m:Text text="{excelModel>NetPrice}" wrapping="false"/>
                </template>
            </Column>

            <Column width="4rem" hAlign="Center" sortProperty="Currency" filterProperty="Currency">
                <m:Label text="Curr." tooltip="Currency"/>
                <template>
                    <m:Text text="{excelModel>Currency}" wrapping="false"/>
                </template>
            </Column>

            <Column width="5rem" hAlign="Center" sortProperty="Plant" filterProperty="Plant">
                <m:Label text="Plant" tooltip="Plant"/>
                <template>
                    <m:Text text="{excelModel>Plant}" wrapping="false"/>
                </template>
            </Column>

            
        </columns>
    </Table>
</core:FragmentDefinition>