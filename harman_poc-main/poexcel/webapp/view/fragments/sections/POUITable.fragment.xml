            <Column width="5rem" hAlign="Center">
                <m:Label text="Action"/>
                <template>
                    <m:Button
                        icon="sap-icon://action"
                        press=".onActionButtonPress"
                        ariaHasPopup="Menu" 
                        class="poActionBtn">
                        <m:dependents>
                            <core:Fragment
                                fragmentName="com.sap.poexcel.view.fragments.ActionSheet"
                                type="XML" />
                        </m:dependents>
                    </m:Button>
                </template>
            </Column>
            <Column width="7rem" sortProperty="Quantity" filterProperty="Quantity">
                <m:Label text="Quantity"/>
                <template>
                    <m:Input value="{path: 'excelModel>Quantity', type: 'sap.ui.model.type.String', constraints: { search: '^[0-9]+$' }}"
                        visible="{= ${excelModel>ConfirmationCategory} !== undefined &amp;&amp; ${excelModel>ConfirmationCategory} !== '' }"
                        editable="{= ${excelModel>ConfirmationCategory} === 'LA' || ${excelModel>StatusFlag} === 'R' ? false : true }"
                        liveChange=".onQuantityLiveChange"/>
                </template>
            </Column>

            <Column width="9rem" hAlign="Center" sortProperty="CreationDate" filterProperty="CreationDate">
                <m:Label text="Conf. Delivery Date"/>
                <template>
                    <m:DatePicker valueState="{excelModel>DateState}" valueStateText="{excelModel>DateMsg}" value="{excelModel>CreationDate}"
                        visible="{= ${excelModel>ConfirmationCategory} !== undefined &amp;&amp; ${excelModel>ConfirmationCategory} !== '' }"
                        enabled="{= ${excelModel>ConfirmationCategory} === 'LA' || ${excelModel>StatusFlag} === 'R' ? false : true }"
                        valueFormat="MM/dd/yyyy" displayFormat="MM/dd/yyyy" placeholder="MM/DD/YYYY" change="onDateLiveChange"/>
                </template>
            </Column>

            <!-- <Column width="9rem" sortProperty="Reference" filterProperty="Reference">
                <m:Label text="Reference"/>
                <template>
                    <m:Input value="{excelModel>Reference}" visible="{= ${excelModel>ConfirmationCategory} !== undefined &amp;&amp; ${excelModel>ConfirmationCategory} !== '' }"
                        editable="{= ${excelModel>newRecFlag} === false || ${excelModel>StatusFlag} === 'R' ? false : true }"/>
                </template>
            </Column>
            <Column width="9rem" sortProperty="MRPMaterial" filterProperty="MRPMaterial">
                <m:Label text="MRP Material"/>
                <template>
                    <m:Input value="{excelModel>MRPMaterial}" visible="{= ${excelModel>ConfirmationCategory} !== undefined &amp;&amp; ${excelModel>ConfirmationCategory} !== '' }"
                        editable="{= ${excelModel>newRecFlag} === false || ${excelModel>StatusFlag} === 'R' ? false : true }"/>
                </template>
            </Column> -->
            <Column width="9rem" sortProperty="PONumber" filterProperty="PONumber">
                <m:Label text="PO Number"/>
                <template>
                    <m:ObjectIdentifier title="{excelModel>PONumber}"/>
                </template>
            </Column>

            <Column width="7rem" sortProperty="VendorCode" filterProperty="VendorCode">
                <m:Label text="Vendor Code"/>
                <template>
                    <m:Text text="{excelModel>VendorCode}" wrapping="false"/>
                </template>
            </Column>

            <!-- <Column width="12rem" sortProperty="VendorName" filterProperty="VendorName">
