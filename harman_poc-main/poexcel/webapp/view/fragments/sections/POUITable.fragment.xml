<core:FragmentDefinition
    xmlns="sap.ui.table"
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
>
    <Table
        id="idFlatPOGridTable"
        class="sapUiSizeCompact"
        rows="{excelModel>/data}"
        selectionMode="None"
        visibleRowCountMode="Interactive"
        visibleRowCount="5"
        enableGrouping="true"
    >
        <extension>
            <m:OverflowToolbar style="Clear">
                <m:Title text="Purchase Orders, Items &amp; Confirmations Grid" level="H5"/>
                <m:ToolbarSpacer/>
                <!-- <m:Button icon="sap-icon://add" type="Emphasized" tooltip="Add Row" press=".onAddVendorRowSP"/> -->
            </m:OverflowToolbar>
        </extension>

        <columns>
