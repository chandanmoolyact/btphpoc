            </Column> -->

            

            <Column width="5rem" hAlign="Center" sortProperty="EDIFlag" filterProperty="EDIFlag">
                <m:Label text="EDI"/>
                <template>
                    <m:ObjectStatus inverted="true"
                        visible="{= ${excelModel>EDIFlag} === 'E' ? true : false}"
                        text="{= ${excelModel>EDIFlag} === 'E' ? 'EDI' : 'SAP'}"
                        state="{= ${excelModel>EDIFlag} === 'E' ? 'Warning' : 'Information'}"/>
                </template>
            </Column>

            <Column width="4rem" hAlign="Center" sortProperty="ConfirmationCategory" filterProperty="ConfirmationCategory">
                <m:Label text="CC"/>
                <template>
                    <m:Text text="{excelModel>ConfirmationCategory}" wrapping="false"/>
                </template>
            </Column>


            <Column width="4rem" hAlign="Center" sortProperty="Item" filterProperty="Item">
                <m:Label text="Conf. Item"/>
                <template>
                    <m:Text text="{excelModel>Item}" wrapping="false"/>
                </template>
            </Column>

            <Column width="6rem" hAlign="Center" sortProperty="StatusFlag" filterProperty="StatusFlag">
                <m:Label text="Conf. Status"/>
                <template>
                    <m:ObjectStatus inverted="true" visible="{= ${excelModel>StatusFlag} !== undefined &amp;&amp; ${excelModel>StatusFlag} !== '' }"
                        text="{= ${excelModel>StatusFlag} === 'R' ? 'Rejected' : (${excelModel>StatusFlag} === 'A' ? 'Approved' : 'NA')}"
                        state="{= ${excelModel>StatusFlag} === 'R' ? 'Error' : (${excelModel>StatusFlag} === 'A' ? 'Success' : 'Information')}"/>
                </template>
            </Column>

